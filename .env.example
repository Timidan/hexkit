# WalletConnect Project ID (required for wallet connections)
# Get yours from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Etherscan V2 API Key (optional — enables faster contract lookups across all chains)
# Get a free key from https://etherscan.io/myapikey
VITE_ETHERSCAN_API_KEY=your-etherscan-api-key

# Simulator Bridge URL (optional — defaults to http://127.0.0.1:5789)
# VITE_SIMULATOR_BRIDGE_URL=http://127.0.0.1:5789
