# Dynamic SDK Configuration
# Get your environment ID from https://app.dynamic.xyz
VITE_DYNAMIC_ENVIRONMENT_ID=your-environment-id-here

# WalletConnect Project ID (optional but recommended)
# Get yours from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# API Keys for Block Explorers (optional)
VITE_ETHERSCAN_API_KEY=your-etherscan-api-key
VITE_POLYGONSCAN_API_KEY=your-polygonscan-api-key
VITE_BSCSCAN_API_KEY=your-bscscan-api-key
VITE_ARBISCAN_API_KEY=your-arbiscan-api-key
VITE_OPTIMISTIC_ETHERSCAN_API_KEY=your-optimistic-etherscan-api-key
VITE_BASESCAN_API_KEY=your-basescan-api-key
VITE_SNOWTRACE_API_KEY=your-snowtrace-api-key