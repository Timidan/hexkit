import React, { useState } from 'react';
import { ethers } from 'ethers';
import { Sparkles, Lightbulb, FileText, Zap, TrendingUp, Settings, Copy, Rocket, CheckCircle, Building2, Code2, Hash, Search } from 'lucide-react';
import ABIFetcher from './ABIFetcher';
import EnhancedStructInput from './EnhancedStructInput';
import AdvancedJsonEditor from './AdvancedJsonEditor';
import EnhancedError from './EnhancedError';
import AnimatedInput from './ui/AnimatedInput';
import AnimatedButton from './ui/AnimatedButton';
import { useToolkit } from '../contexts/ToolkitContext';
import '../styles/EnhancedStructInput.css';
import '../styles/AdvancedJsonEditor.css';
import '../styles/AnimatedInput.css';
import '../styles/AnimatedButton.css';
import '../styles/SimpleGridUI.css';

const CalldataGenerator: React.FC = () => {
  const toolkit = useToolkit();
  
  // Component state
  const [abi, setAbi] = useState('');
  const [selectedFunction, setSelectedFunction] = useState('');
  const [inputs, setInputs] = useState<Record<string, string>>({});
  const [structuredInputs, setStructuredInputs] = useState<any[]>([]);
  const [inputMethod, setInputMethod] = useState<'enhanced' | 'json' | 'simple'>('json');
  const [calldata, setCalldata] = useState('');
  const [contractAddress, setContractAddress] = useState('');
  const [showTransferOptions, setShowTransferOptions] = useState(false);
  const [selectedContract, setSelectedContract] = useState('');
  const [error, setError] = useState<string | null>(null);
  const [recentAddresses, setRecentAddresses] = useState<string[]>([]);

  const generateCalldata = () => {
    try {
      const iface = new ethers.utils.Interface(abi);
      
      let args: any[];
      
      if ((inputMethod === 'enhanced' || inputMethod === 'json') && structuredInputs.length > 0) {
        // Use the structured inputs from EnhancedStructInput or AdvancedJsonEditor
        args = structuredInputs;
      } else {
        // Fallback to legacy input parsing
        const func = JSON.parse(abi).find(
          (f: any) => f.name === selectedFunction
        );

        args = func.inputs.map((input: any) => {
          const value = inputs[input.name] || '';
          if (input.type.includes('uint')) return value || '0';
          if (input.type === 'bool') return value === 'true';
          return value;
        });
      }

      const encoded = iface.encodeFunctionData(selectedFunction, args);
      setCalldata(encoded);
      setError(null);

      // Share generated data with toolkit context
      if (contractAddress) {
        toolkit.setGeneratedCalldata({
          contractAddress,
          functionName: selectedFunction,
          calldata: encoded,
          abi: JSON.parse(abi),
          parameters: inputs,
        });
        setShowTransferOptions(true);
        
        // Add to recent addresses
        if (!recentAddresses.includes(contractAddress)) {
          setRecentAddresses([contractAddress, ...recentAddresses.slice(0, 4)]);
        }
      }
    } catch (e: any) {
      setError(e.message);
      setCalldata('');
      setShowTransferOptions(false);
    }
  };

  const handleTransferToBuilder = () => {
    if (toolkit.lastGeneratedCalldata) {
      toolkit.transferToTransactionBuilder(toolkit.lastGeneratedCalldata);
      setShowTransferOptions(false);
    }
  };

  const handleTestInDecoder = () => {
    // Navigate to decoder - we could enhance this to pre-populate calldata
    toolkit.navigateToDecoder();
    setShowTransferOptions(false);
  };

  const handleContractSelect = (contractKey: string) => {
    if (contractKey === '') {
      // Clear selection
      setSelectedContract('');
      return;
    }

    const contract = toolkit.recentContractData.find((_, index) => 
      `${_.address}_${index}` === contractKey
    );
    
    if (contract) {
      setSelectedContract(contractKey);
      setContractAddress(contract.address);
      setAbi(JSON.stringify(contract.abi, null, 2));
      
      // Clear previous function selection
      setSelectedFunction('');
      setInputs({});
      setCalldata('');
      setShowTransferOptions(false);
    }
  };

  const headerStyle = {
    fontSize: "32px",
    fontWeight: "bold",
    background: "linear-gradient(45deg, #007bff, #28a745)",
    WebkitBackgroundClip: "text",
    WebkitTextFillColor: "transparent",
    backgroundClip: "text",
    marginBottom: "8px",
  };

  const gridStyle = {
    display: "grid",
    gridTemplateColumns: "1.6fr 1fr",
    gap: "24px",
    maxWidth: "1600px",
    margin: "0 auto",
  };

  const cardStyle = {
    background: "linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%)",
    border: "1px solid #333",
    borderRadius: "12px",
    padding: "24px",
    boxShadow: "0 8px 32px rgba(0, 0, 0, 0.3)",
  };

  const subHeaderStyle = {
    fontSize: "20px",
    fontWeight: "600",
    marginBottom: "20px",
    color: "#fff",
  };

  return (
    <div
      style={{
        minHeight: "100vh",
        background: "#0a0a0a",
        color: "#fff",
        padding: "20px",
      }}
    >
      {/* Header */}
      <div style={{ textAlign: "center", marginBottom: "40px" }}>
        <h1 style={headerStyle}>Generate Calldata</h1>
        <p style={{ color: "#888", fontSize: "16px" }}>
          Encode function calls with proper ABI validation
        </p>
      </div>

      {/* Main Grid */}
      <div style={gridStyle}>
        {/* LEFT COLUMN - Contract */}
        <div style={cardStyle}>
          <h2 style={subHeaderStyle}>🔧 Contract Setup</h2>

          {/* Contract Selection */}
          <div style={{ marginBottom: "24px" }}>
            <h3 style={{ fontSize: "16px", fontWeight: "600", marginBottom: "12px", display: "flex", alignItems: "center", gap: "8px" }}>
              <Building2 size={16} />
              Contract Selection
            </h3>
            
            {toolkit.recentContractData.length > 0 ? (
              <div style={{ marginBottom: "16px" }}>
                <select
                  value={selectedContract}
                  onChange={(e) => handleContractSelect(e.target.value)}
                  style={{
                    width: "100%",
                    padding: "12px",
                    background: "rgba(255, 255, 255, 0.1)",
                    border: "1px solid #333",
                    borderRadius: "8px",
                    color: "#fff",
                    fontSize: "14px",
                    marginBottom: "8px"
                  }}
                >
                  <option value="">Choose from imported contracts...</option>
                  {toolkit.recentContractData.map((contract, index) => {
                    const contractKey = `${contract.address}_${index}`;
                    const shortAddress = `${contract.address.slice(0, 6)}...${contract.address.slice(-4)}`;
                    const functionCount = contract.functions ? contract.functions.length : 
                      contract.abi.filter((item: any) => item.type === 'function').length;
                    
                    return (
                      <option key={contractKey} value={contractKey}>
                        {contract.name || 'Unnamed Contract'} - {shortAddress} ({functionCount} functions)
                      </option>
                    );
                  })}
                </select>
                <div style={{ fontSize: "12px", color: "#888", display: "flex", alignItems: "center", gap: "4px" }}>
                  <Sparkles size={12} />
                  Contracts from Signature Database uploads
                </div>
              </div>
            ) : (
              <div style={{
                background: "rgba(33, 150, 243, 0.1)",
                border: "1px solid rgba(33, 150, 243, 0.3)",
                borderRadius: "8px",
                padding: "12px",
                fontSize: "13px",
                color: "#64b5f6",
                display: "flex",
                alignItems: "center",
                gap: "8px"
              }}>
                <Lightbulb size={16} />
                <span>Upload contract artifacts in <strong>Signature Database</strong> to quickly select contracts here</span>
              </div>
            )}
          </div>

            {/* Manual Setup */}
            <div style={{ marginBottom: "24px" }}>
              <h3 style={{ fontSize: "16px", fontWeight: "600", marginBottom: "12px", display: "flex", alignItems: "center", gap: "8px" }}>
                <Settings size={16} />
                Manual Contract Setup
              </h3>
              
              {toolkit.recentContractData.length > 0 && (
                <div style={{
                  fontSize: "12px",
                  color: "#888",
                  marginBottom: "16px",
                  padding: "8px 12px",
                  background: "rgba(255, 255, 255, 0.05)",
                  borderRadius: "6px",
                  border: "1px solid rgba(255, 255, 255, 0.1)"
                }}>
                  <span>OR use manual setup below</span>
                </div>
              )}

              <div style={{ marginBottom: "16px" }}>
                <ABIFetcher onABIFetched={(fetchedAbi) => {
                  setAbi(fetchedAbi);
                  if (selectedContract) {
                    setSelectedContract('');
                  }
                }} />
              </div>

              <div style={{ position: "relative" }}>
                <AnimatedInput
                  label="Contract Address"
                  value={contractAddress}
                  onChange={setContractAddress}
                  type="text"
                  placeholder="0x1234567890abcdef1234567890abcdef12345678"
                  icon={<Building2 size={20} />}
                  className={selectedContract ? 'contract-selected' : ''}
                />
                {selectedContract && (
                  <div style={{
                    fontSize: "12px",
                    color: "#22c55e",
                    marginTop: "4px",
                    display: "flex",
                    alignItems: "center",
                    gap: "4px"
                  }}>
                    ✅ Populated from selected contract
                  </div>
                )}
              </div>
            </div>

            {/* Function Selection */}
            {abi && (
              <div style={{ marginBottom: "24px" }}>
                <h3 style={{ fontSize: "16px", fontWeight: "600", marginBottom: "12px", display: "flex", alignItems: "center", gap: "8px" }}>
                  <Zap size={16} />
                  Function Selection
                </h3>
                
                <select
                  value={selectedFunction}
                  onChange={(e) => setSelectedFunction(e.target.value)}
                  style={{
                    width: "100%",
                    padding: "12px",
                    background: "rgba(255, 255, 255, 0.1)",
                    border: "1px solid #333",
                    borderRadius: "8px",
                    color: "#fff",
                    fontSize: "14px",
                    cursor: "pointer"
                  }}
                >
                  <option value="">Select a function...</option>
                  {(() => {
                    try {
                      return JSON.parse(abi)
                        .filter((item: any) => item.type === 'function')
                        .map((func: any) => (
                          <option key={func.name} value={func.name}>
                            {func.name}({func.inputs.map((input: any) => `${input.type} ${input.name}`).join(', ')})
                          </option>
                        ));
                    } catch {
                      return [];
                    }
                  })()}
                </select>
              </div>
            )}

            {/* Parameters Input */}
            {selectedFunction && (
              <div style={{ marginBottom: "24px" }}>
                <h3 style={{ fontSize: "16px", fontWeight: "600", marginBottom: "12px", display: "flex", alignItems: "center", gap: "8px" }}>
                  <Hash size={16} />
                  Function Parameters
                </h3>
                
                <div style={{ 
                  display: "flex", 
                  gap: "8px", 
                  marginBottom: "16px",
                  background: "rgba(255, 255, 255, 0.05)",
                  borderRadius: "8px",
                  padding: "4px"
                }}>
                  <button
                    style={{
                      padding: "8px 16px",
                      background: inputMethod === 'simple' ? "#007bff" : "transparent",
                      color: inputMethod === 'simple' ? "#fff" : "#888",
                      border: "none",
                      borderRadius: "6px",
                      cursor: "pointer",
                      fontSize: "14px",
                      fontWeight: "500",
                      transition: "all 0.2s ease"
                    }}
                    onClick={() => setInputMethod('simple')}
                  >
                    Simple
                  </button>
                  <button
                    style={{
                      padding: "8px 16px",
                      background: inputMethod === 'json' ? "#007bff" : "transparent",
                      color: inputMethod === 'json' ? "#fff" : "#888",
                      border: "none",
                      borderRadius: "6px",
                      cursor: "pointer",
                      fontSize: "14px",
                      fontWeight: "500",
                      transition: "all 0.2s ease"
                    }}
                    onClick={() => setInputMethod('json')}
                  >
                    JSON Editor
                  </button>
                  <button
                    style={{
                      padding: "8px 16px",
                      background: inputMethod === 'enhanced' ? "#007bff" : "transparent",
                      color: inputMethod === 'enhanced' ? "#fff" : "#888",
                      border: "none",
                      borderRadius: "6px",
                      cursor: "pointer",
                      fontSize: "14px",
                      fontWeight: "500",
                      transition: "all 0.2s ease"
                    }}
                    onClick={() => setInputMethod('enhanced')}
                  >
                    Enhanced
                  </button>
                </div>
                  
                  {(() => {
                    try {
                      const func = JSON.parse(abi).find((f: any) => f.name === selectedFunction);
                      
                      if (inputMethod === 'enhanced') {
                        return (
                          <EnhancedStructInput
                            inputs={func.inputs}
                            onInputChange={(structuredData) => {
                              setStructuredInputs(structuredData);
                            }}
                          />
                        );
                      } else if (inputMethod === 'json') {
                        return (
                          <AdvancedJsonEditor
                            inputs={func.inputs}
                            onInputChange={(structuredData) => {
                              setStructuredInputs(structuredData);
                            }}
                          />
                        );
                      } else {
                        return (
                          <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
                            {func.inputs.map((input: any) => {
                              const { name, type } = input;
                              return (
                                <AnimatedInput
                                  key={name}
                                  label={`${name} (${type})`}
                                  value={inputs[name]}
                                  onChange={(value) => setInputs({ ...inputs, [name]: value })}
                                  type="text"
                                  placeholder={type.includes('uint') ? '0' : type === 'bool' ? 'true/false' : `Enter ${type} value`}
                                  icon={<Hash size={20} />}
                                />
                              );
                            })}
                          </div>
                        );
                      }
                    } catch {
                      return <div style={{ color: "#ef4444", padding: "12px", background: "rgba(239, 68, 68, 0.1)", borderRadius: "6px", border: "1px solid rgba(239, 68, 68, 0.3)" }}>Invalid ABI format</div>;
                    }
                  })()}
              </div>
            )}

            {/* Generate Button */}
            <div style={{ marginBottom: "24px", textAlign: "center" }}>
              <AnimatedButton
                onClick={generateCalldata}
                disabled={!abi || !selectedFunction}
                variant="primary"
                size="lg"
                icon={<Rocket size={20} />}
              >
                Generate Calldata
              </AnimatedButton>
            </div>

            {/* Error Display */}
            {error && <EnhancedError error={error} />}

            {/* Results */}
            {calldata && (
              <div style={{
                background: "linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%)",
                border: "1px solid #333",
                borderRadius: "12px",
                padding: "24px",
                boxShadow: "0 8px 32px rgba(0, 0, 0, 0.3)",
                marginBottom: "24px"
              }}>
                <div style={{
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                  marginBottom: "20px",
                  paddingBottom: "16px",
                  borderBottom: "1px solid #333"
                }}>
                  <h3 style={{
                    fontSize: "18px",
                    fontWeight: "600",
                    margin: "0",
                    display: "flex",
                    alignItems: "center",
                    gap: "8px",
                    color: "#fff"
                  }}>
                    <CheckCircle size={18} style={{ color: '#22c55e' }} />
                    Generated Calldata
                  </h3>
                  <div style={{ display: "flex", gap: "16px" }}>
                    <span style={{
                      display: "flex",
                      alignItems: "center",
                      gap: "4px",
                      fontSize: "12px",
                      color: "#888",
                      background: "rgba(255, 255, 255, 0.05)",
                      padding: "4px 8px",
                      borderRadius: "6px"
                    }}>
                      <TrendingUp size={16} />
                      {(calldata.length - 2) / 2} bytes
                    </span>
                    <span style={{
                      display: "flex",
                      alignItems: "center",
                      gap: "4px",
                      fontSize: "12px",
                      color: "#888",
                      background: "rgba(255, 255, 255, 0.05)",
                      padding: "4px 8px",
                      borderRadius: "6px"
                    }}>
                      <Settings size={16} />
                      {selectedFunction}
                    </span>
                  </div>
                </div>
                
                <div>
                  <div style={{
                    position: "relative",
                    background: "rgba(0, 0, 0, 0.3)",
                    border: "1px solid #333",
                    borderRadius: "8px",
                    padding: "16px",
                    marginBottom: "16px"
                  }}>
                    <code style={{
                      color: "#64b5f6",
                      fontFamily: "'SF Mono', 'Monaco', 'Consolas', monospace",
                      fontSize: "14px",
                      wordBreak: "break-all",
                      lineHeight: "1.5"
                    }}>{calldata}</code>
                    <button 
                      onClick={() => navigator.clipboard.writeText(calldata)}
                      style={{
                        position: "absolute",
                        top: "12px",
                        right: "12px",
                        background: "rgba(255, 255, 255, 0.1)",
                        border: "1px solid #333",
                        borderRadius: "6px",
                        padding: "8px",
                        color: "#fff",
                        cursor: "pointer",
                        transition: "all 0.2s ease"
                      }}
                      title="Copy calldata"
                    >
                      <Copy size={16} />
                    </button>
                  </div>
                  
                  <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
                    <div style={{
                      display: "flex",
                      justifyContent: "space-between",
                      alignItems: "center",
                      padding: "12px",
                      background: "rgba(255, 255, 255, 0.03)",
                      borderRadius: "6px"
                    }}>
                      <span style={{ fontSize: "14px", color: "#888" }}>Function Selector:</span>
                      <code style={{
                        fontSize: "14px",
                        color: "#64b5f6",
                        fontFamily: "'SF Mono', 'Monaco', 'Consolas', monospace"
                      }}>{calldata.slice(0, 10)}</code>
                    </div>
                    {calldata.length > 10 && (
                      <div style={{
                        display: "flex",
                        justifyContent: "space-between",
                        alignItems: "center",
                        padding: "12px",
                        background: "rgba(255, 255, 255, 0.03)",
                        borderRadius: "6px"
                      }}>
                        <span style={{ fontSize: "14px", color: "#888" }}>Parameters:</span>
                        <code style={{
                          fontSize: "14px",
                          color: "#64b5f6",
                          fontFamily: "'SF Mono', 'Monaco', 'Consolas', monospace",
                          wordBreak: "break-all",
                          maxWidth: "60%",
                          textAlign: "right"
                        }}>{calldata.slice(10)}</code>
                      </div>
                    )}
                  </div>
                </div>
                
                {/* Transfer Options */}
                {showTransferOptions && (
                  <div style={{
                    marginTop: "24px",
                    paddingTop: "20px",
                    borderTop: "1px solid #333"
                  }}>
                    <h3 style={{
                      fontSize: "16px",
                      fontWeight: "600",
                      marginBottom: "16px",
                      display: "flex",
                      alignItems: "center",
                      gap: "8px",
                      color: "#fff"
                    }}>
                      <Rocket size={18} />
                      Next Steps
                    </h3>
                    <div style={{
                      display: "grid",
                      gridTemplateColumns: "1fr 1fr",
                      gap: "16px"
                    }}>
                      <button 
                        onClick={handleTransferToBuilder}
                        style={{
                          background: "linear-gradient(135deg, rgba(0, 123, 255, 0.2) 0%, rgba(40, 167, 69, 0.2) 100%)",
                          border: "1px solid #007bff",
                          borderRadius: "8px",
                          padding: "16px",
                          cursor: "pointer",
                          transition: "all 0.3s ease",
                          textAlign: "left"
                        }}
                      >
                        <div style={{
                          display: "flex",
                          alignItems: "center",
                          gap: "12px"
                        }}>
                          <div style={{
                            background: "rgba(0, 123, 255, 0.3)",
                            padding: "8px",
                            borderRadius: "6px",
                            display: "flex",
                            alignItems: "center",
                            justifyContent: "center"
                          }}>
                            <Building2 size={20} />
                          </div>
                          <div>
                            <div style={{
                              fontSize: "14px",
                              fontWeight: "600",
                              color: "#fff",
                              marginBottom: "4px"
                            }}>Build Transaction</div>
                            <div style={{
                              fontSize: "12px",
                              color: "#888"
                            }}>Execute this function call on-chain</div>
                          </div>
                        </div>
                      </button>
                      <button 
                        onClick={handleTestInDecoder}
                        style={{
                          background: "rgba(255, 255, 255, 0.05)",
                          border: "1px solid #333",
                          borderRadius: "8px",
                          padding: "16px",
                          cursor: "pointer",
                          transition: "all 0.3s ease",
                          textAlign: "left"
                        }}
                      >
                        <div style={{
                          display: "flex",
                          alignItems: "center",
                          gap: "12px"
                        }}>
                          <div style={{
                            background: "rgba(139, 92, 246, 0.3)",
                            padding: "8px",
                            borderRadius: "6px",
                            display: "flex",
                            alignItems: "center",
                            justifyContent: "center"
                          }}>
                            <Search size={20} />
                          </div>
                          <div>
                            <div style={{
                              fontSize: "14px",
                              fontWeight: "600",
                              color: "#fff",
                              marginBottom: "4px"
                            }}>Verify in Decoder</div>
                            <div style={{
                              fontSize: "12px",
                              color: "#888"
                            }}>Double-check the generated calldata</div>
                          </div>
                        </div>
                      </button>
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>

          {/* RIGHT COLUMN - Additional Tools */}
          <div style={cardStyle}>
            <h2 style={subHeaderStyle}>🛠️ Tools & Resources</h2>

            {/* Quick Actions */}
            <div style={{ marginBottom: "24px" }}>
              <h3 style={{ fontSize: "16px", fontWeight: "600", marginBottom: "12px", display: "flex", alignItems: "center", gap: "8px" }}>
                <Zap size={16} />
                Quick Actions
              </h3>
              
              <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
                <button
                  style={{
                    padding: "12px",
                    background: "rgba(255, 255, 255, 0.05)",
                    border: "1px solid #333",
                    borderRadius: "6px",
                    color: "#fff",
                    cursor: "pointer",
                    fontSize: "14px",
                    textAlign: "left",
                    transition: "all 0.2s ease"
                  }}
                  onClick={() => {
                    setAbi('');
                    setSelectedFunction('');
                    setInputs({});
                    setCalldata('');
                    setContractAddress('');
                    setSelectedContract('');
                    setShowTransferOptions(false);
                  }}
                >
                  🔄 Clear All Fields
                </button>
                
                <button
                  style={{
                    padding: "12px",
                    background: "rgba(255, 255, 255, 0.05)",
                    border: "1px solid #333",
                    borderRadius: "6px",
                    color: "#fff",
                    cursor: "pointer",
                    fontSize: "14px",
                    textAlign: "left",
                    transition: "all 0.2s ease"
                  }}
                  onClick={() => toolkit.navigateToDatabase()}
                >
                  📁 Browse Signature Database
                </button>
              </div>
            </div>

            {/* Recent Addresses */}
            {recentAddresses.length > 0 && (
              <div style={{ marginBottom: "24px" }}>
                <h3 style={{ fontSize: "16px", fontWeight: "600", marginBottom: "12px", display: "flex", alignItems: "center", gap: "8px" }}>
                  <FileText size={16} />
                  Recent Addresses
                </h3>
                
                <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
                  {recentAddresses.slice(0, 3).map((address, index) => (
                    <button
                      key={index}
                      style={{
                        padding: "8px 12px",
                        background: "rgba(255, 255, 255, 0.03)",
                        border: "1px solid #333",
                        borderRadius: "6px",
                        color: "#888",
                        cursor: "pointer",
                        fontSize: "12px",
                        textAlign: "left",
                        fontFamily: "'SF Mono', 'Monaco', 'Consolas', monospace",
                        transition: "all 0.2s ease"
                      }}
                      onClick={() => setContractAddress(address)}
                    >
                      {`${address.slice(0, 6)}...${address.slice(-4)}`}
                    </button>
                  ))}
                </div>
              </div>
            )}

            {/* Help & Tips */}
            <div>
              <h3 style={{ fontSize: "16px", fontWeight: "600", marginBottom: "12px", display: "flex", alignItems: "center", gap: "8px" }}>
                <Lightbulb size={16} />
                Tips
              </h3>
              
              <div style={{
                background: "rgba(33, 150, 243, 0.1)",
                border: "1px solid rgba(33, 150, 243, 0.3)",
                borderRadius: "8px",
                padding: "16px"
              }}>
                <div style={{ fontSize: "13px", color: "#64b5f6", lineHeight: "1.5" }}>
                  <p style={{ margin: "0 0 8px 0" }}>💡 <strong>Pro Tips:</strong></p>
                  <ul style={{ margin: "0", paddingLeft: "16px" }}>
                    <li>Use the Signature Database to import contract ABIs automatically</li>
                    <li>Enhanced mode provides intelligent input validation for complex types</li>
                    <li>Copy generated calldata to use in external tools or scripts</li>
                    <li>Transfer to Transaction Builder for on-chain execution</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default CalldataGenerator;